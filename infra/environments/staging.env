# Staging environment — the ONE source of truth for the environment-specific
# values that provision-staging.sh, setup-wif.sh, and .github/workflows/
# deploy-staging.yml all need (OFC-84). Previously each hardcoded these
# independently, and a drift between them had to be hand-fixed across three files.
#
# Consumed two ways, both of which tolerate these comments:
#   - the shell scripts `source` this file (their ${VAR:-default} still applies);
#   - the deploy workflow appends the KEY=VALUE lines to $GITHUB_ENV.
#
# Format rules (so BOTH consumers stay happy): plain KEY=VALUE, one per line, no
# quotes, no spaces around `=`, no spaces in values. Comments/blanks are ignored.
# A prod environment gets a sibling prod.env with the pbe400.org / prod values.

# Project + region
PROJECT_ID=pbe-book-staging
REGION=us-central1

# Cloud Run service + its runtime service account (D83 scale-to-zero, one instance)
SERVICE=pbe-book-api
SA_NAME=book-api
RUNTIME_SA=book-api@pbe-book-staging.iam.gserviceaccount.com

# Private member-image bucket (D126 — app-served, no CDN/LB)
IMAGE_BUCKET=pbe-book-staging-images

# Keyless CI deploy identity (setup-wif.sh) — none of these are secrets
GITHUB_REPO=fthiess/pbe-address-book
DEPLOYER_SA=github-deployer@pbe-book-staging.iam.gserviceaccount.com
WIF_PROVIDER=projects/268373129203/locations/global/workloadIdentityPools/github-pool/providers/github-provider

# Ghost auth bridge (Phase 1b) — self-hosted ghost-staging (D72, amended)
GHOST_JWKS_URL=https://staging.pbe400.org/members/.well-known/jwks.json
GHOST_JWT_ISSUER=https://staging.pbe400.org/members/api
GHOST_JWT_AUDIENCE=https://staging.pbe400.org/members/api
GHOST_BRIDGE_URL=https://staging.pbe400.org/book
GHOST_BRIDGE_TARGET=staging

# Ghost Admin API (Phase 5b-1 write path). The KEY is NOT here — it lives in Secret
# Manager (secret `ghost-admin-api-key`) and is referenced by the Cloud Run deploy
# via --set-secrets. These two are non-secret. GHOST_NEWSLETTER_ID is ghost-staging's
# "PBE News (Staging)" newsletter (must-verify N67, confirmed live).
GHOST_ADMIN_API_URL=https://staging.pbe400.org/ghost/api/admin
GHOST_NEWSLETTER_ID=6a3ebdd8415f8e0001858cb0

# The sibling newsletter URL the SPA's masthead "PBE News" link points at (OFC-243/
# N94). Injected into the web build via $GITHUB_ENV (vite.config reads
# BOOK_PBE_NEWS_URL). Staging points at ghost-staging; a prod.env would set the
# pbe400.org value, and an unset build defaults to pbe400.org.
BOOK_PBE_NEWS_URL=https://staging.pbe400.org
